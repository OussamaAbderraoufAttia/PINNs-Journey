    from src.pinns.utils.derivatives import gradient, jacobian, hessian, laplacian, divergence, time_derivative, spatial_gradient\n\n# Test gradient\nx = torch.tensor([[1.0, 2.0], [3.0, 4.0]], requires_grad=True)\ny = x[:, 0]**2 + x[:, 1]**3  # Shape: (2,)\n\ngrad = gradient(y, x)\nprint(f\"gradient shape: {grad.shape}\")\nprint(f\"gradient:\\n{grad}\")\nprint(f\"Expected: [[2*1, 3*2^2], [2*3, 3*4^2]] = [[2, 12], [6, 48]]\")\n\n# Test jacobian\nf = torch.stack([x[:, 0]**2, x[:, 1]**3, x[:, 0]*x[:, 1]], dim=1)  # (2, 3)\nJ = jacobian(f, x)\nprint(f\"\\njacobian shape: {J.shape}\")\nprint(f\"jacobian:\\n{J}\")\n\n# Test laplacian\nu_scalar = x[:, 0]**2 + x[:, 1]**2\nlap = laplacian(u_scalar, x)\nprint(f\"\\nlaplacian: {lap}\")  # Should be [4, 4]\n\n# Test time_derivative\nt = torch.tensor([[0.5], [1.0]], requires_grad=True)\nu_t = torch.sin(torch.pi * x[:, 0:1]) * torch.exp(-torch.pi**2 * t)\nut = time_derivative(u_t, t)\nprint(f\"\\ntime derivative: {ut.flatten()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Common Pitfalls and Best Practices\n",
    "\n",
    "### Pitfall 1: Forgetting `create_graph=True` for higher-order derivatives\n",
    "### Pitfall 2: Not using `retain_graph=True` when computing multiple gradients\n",
    "### Pitfall 3: Forgetting `grad_outputs` for non-scalar outputs\n",
    "### Pitfall 4: Accumulating gradients without `zero_grad()`\n",
    "### Pitfall 5: In-place operations breaking the computational graph"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    # Demonstrate common mistakes\nprint(\"=== Pitfall 1: Missing create_graph ===\")\nx = torch.tensor(2.0, requires_grad=True)\ny = x**3\ntry:\n    dy = torch.autograd.grad(y, x)[0]  # No create_graph\n    d2y = torch.autograd.grad(dy, x)[0]\nexcept RuntimeError as e:\n    print(f\"Error: {e}\")\n\nprint(\"\\n=== Pitfall 2: Missing retain_graph ===\")\nx = torch.tensor([1.0, 2.0], requires_grad=True)\ny1 = x[0]**2\ny2 = x[1]**3\ntry:\n    g1 = torch.autograd.grad(y1, x)[0]  # Graph freed after this\n    g2 = torch.autograd.grad(y2, x)[0]  # Error!\nexcept RuntimeError as e:\n    print(f\"Error: {e}\")\n\nprint(\"\\n=== Correct way ===\")\nx = torch.tensor([1.0, 2.0], requires_grad=True)\ny1 = x[0]**2\ny2 = x[1]**3\ng1 = torch.autograd.grad(y1, x, retain_graph=True)[0]\ng2 = torch.autograd.grad(y2, x, retain_graph=True)[0]\nprint(f\"g1 = {g1}, g2 = {g2}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
