    # Compute residual field\nmodel_best.eval()\nwith torch.enable_grad():\n    x_res = torch.linspace(x_min, x_max, 100).unsqueeze(1).repeat(1, 100).T.reshape(-1, 1).requires_grad_(True)\n    t_res = torch.linspace(t_min, t_max, 100).unsqueeze(1).repeat(100, 1).reshape(-1, 1).requires_grad_(True)\n    \n    u_res = model_best(x_res, t_res)\n    u_t = torch.autograd.grad(u_res.sum(), t_res, create_graph=True, retain_graph=True)[0]\n    u_x = torch.autograd.grad(u_res.sum(), x_res, create_graph=True, retain_graph=True)[0]\n    u_xx = torch.autograd.grad(u_x.sum(), x_res, create_graph=True, retain_graph=True)[0]\n    \n    residual = (u_t + u_res * u_x - NU * u_xx).detach().reshape(100, 100).numpy()\n    X_res = x_res.detach().reshape(100, 100).numpy()\n    T_res = t_res.detach().reshape(100, 100).numpy()\n\nfig, axes = plt.subplots(1, 2, figsize=(12, 4))\nim1 = axes[0].contourf(X_res, T_res, residual, levels=50, cmap='RdBu_r')\naxes[0].set_xlabel('x'); axes[0].set_ylabel('t')\naxes[0].set_title('PDE Residual')\nplt.colorbar(im1, ax=axes[0])\n\naxes[1].scatter(X_res.flatten(), np.abs(residual).flatten(), s=1, alpha=0.5)\naxes[1].set_xlabel('x'); axes[1].set_ylabel('|Residual|')\naxes[1].set_title('Residual Magnitude')\naxes[1].set_yscale('log')\naxes[1].grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.show()\n\nprint(f\"Max |residual|: {np.max(np.abs(residual)):.2e}\")\nprint(f\"Mean |residual|: {np.mean(np.abs(residual)):.2e}\")"
   ]
