    "## 10. Adaptive Sampling (RAR-G)\n",
    "\n",
    "Residual-based Adaptive Refinement with Gaussian distribution.\n",
    "Add new collocation points where residual is large."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    def train_burgers_adaptive(epochs=10000, adapt_freq=2000, n_add=1000):\n    \"\"\"Train with RAR-G adaptive sampling.\"\"\"\n    torch.manual_seed(42)\n    \n    model = BurgersPINN(hidden_dim=64, num_layers=5, activation='sin')\n    \n    # Initial points\n    n_phys = 5000\n    x_phys = torch.rand(n_phys, 1) * (x_max - x_min) + x_min\n    t_phys = torch.rand(n_phys, 1) * (t_max - t_min) + t_min\n    t_bound = torch.rand(2000, 1) * (t_max - t_min) + t_min\n    x_init = torch.rand(1000, 1) * (x_max - x_min) + x_min\n    \n    optimizer = optim.Adam(model.parameters(), lr=1e-3)\n    \n    history = {'physics': [], 'boundary': [], 'initial': [], 'total': []}\n    \n    for epoch in range(epochs):\n        optimizer.zero_grad()\n        loss, loss_dict = total_loss(model, x_phys, t_phys, t_bound, x_init)\n        loss.backward()\n        optimizer.step()\n        \n        for k, v in loss_dict.items():\n            history[k].append(v)\n        \n        # Adaptive sampling\n        if (epoch + 1) % adapt_freq == 0:\n            model.eval()\n            with torch.enable_grad():\n                # Generate candidates\n                n_cand = 5000\n                x_cand = torch.rand(n_cand, 1) * (x_max - x_min) + x_min\n                t_cand = torch.rand(n_cand, 1) * (t_max - t_min) + t_min\n                x_cand.requires_grad_(True)\n                t_cand.requires_grad_(True)\n                \n                u_cand = model(x_cand, t_cand)\n                u_t = torch.autograd.grad(u_cand.sum(), t_cand, create_graph=True, retain_graph=True)[0]\n                u_x = torch.autograd.grad(u_cand.sum(), x_cand, create_graph=True, retain_graph=True)[0]\n                u_xx = torch.autograd.grad(u_x.sum(), x_cand, create_graph=True, retain_graph=True)[0]\n                \n                res_cand = (u_t + u_cand * u_x - NU * u_xx).detach().abs().flatten()\n                \n                # Select top-n_add points\n                _, top_indices = torch.topk(res_cand, n_add)\n                \n                # Add to training set\n                x_phys = torch.cat([x_phys, x_cand[top_indices]], dim=0)\n                t_phys = torch.cat([t_phys, t_cand[top_indices]], dim=0)\n                \n                print(f\"  Epoch {epoch+1}: Added {n_add} points, total physics points: {len(x_phys)}\")\n            model.train()\n    \n    return model, history\n\nprint(\"Training with adaptive sampling...\")\nmodel_adapt, hist_adapt = train_burgers_adaptive(epochs=8000, adapt_freq=2000, n_add=500)\n\n# Evaluate\nu_adapt, l2_adapt, linf_adapt = evaluate_model(model_adapt, x_fd, t_fd, u_fd)\nprint(f\"Adaptive L2_rel: {l2_adapt:.4e}, L_inf: {linf_adapt:.4e}\")\nprint(f\"Best fixed ({best_act}) L2_rel: {results[best_act]['l2_rel']:.4e}\")"
   ]
