    # Find best model\nbest_act = min(results, key=lambda k: results[k]['l2_rel'])\nprint(f\"Best activation: {best_act}\")\n\nmodel_best = models[best_act]\nu_best = results[best_act]['pred']\n\n# Time slices for comparison\nt_slice_indices = [0, 500, 1000, 2000, 3000, 4000]\nt_labels = [t_fd[i] for i in t_slice_indices]\n\nfig, axes = plt.subplots(2, 3, figsize=(15, 8))\naxes = axes.flatten()\n\nfor i, (idx, t_val) in enumerate(zip(t_slice_indices, t_labels)):\n    axes[i].plot(x_fd, u_fd[idx], 'k--', label='FD Reference', linewidth=2)\n    axes[i].plot(x_fd, u_best[idx], 'b-', label=f'PINN ({best_act})', linewidth=2)\n    axes[i].set_xlabel('x')\n    axes[i].set_ylabel('u')\n    axes[i].set_title(f't = {t_val:.3f}')\n    axes[i].legend()\n    axes[i].grid(True, alpha=0.3)\n    axes[i].set_ylim(-1.2, 1.2)\n\nplt.tight_layout()\nplt.show()"
