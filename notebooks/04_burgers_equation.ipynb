  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Loss Weighting Experiments\n",
    "\n",
    "Burgers equation often needs careful loss balancing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    def train_with_weights(weights_dict, epochs=10000, activation='sin'):\n    torch.manual_seed(42)\n    model = BurgersPINN(hidden_dim=64, num_layers=5, activation=activation)\n    \n    x_phys = torch.rand(10000, 1) * (x_max - x_min) + x_min\n    t_phys = torch.rand(10000, 1) * (t_max - t_min) + t_min\n    t_bound = torch.rand(2000, 1) * (t_max - t_min) + t_min\n    x_init = torch.rand(1000, 1) * (x_max - x_min) + x_min\n    \n    optimizer = optim.Adam(model.parameters(), lr=1e-3)\n    \n    for epoch in range(epochs):\n        optimizer.zero_grad()\n        loss, _ = total_loss(model, x_phys, t_phys, t_bound, x_init, weights=weights_dict)\n        loss.backward()\n        optimizer.step()\n    \n    u_pred, l2_rel, l_inf = evaluate_model(model, x_fd, t_fd, u_fd)\n    return l2_rel, l_inf\n\n# Test different weight combinations\nweight_configs = [\n    {'physics': 1.0, 'boundary': 1.0, 'initial': 1.0},\n    {'physics': 1.0, 'boundary': 10.0, 'initial': 1.0},\n    {'physics': 1.0, 'boundary': 1.0, 'initial': 10.0},\n    {'physics': 10.0, 'boundary': 1.0, 'initial': 1.0},\n    {'physics': 1.0, 'boundary': 100.0, 'initial': 10.0},\n]\n\nprint(\"Testing loss weights...\")\nfor i, w in enumerate(weight_configs):\n    l2, linf = train_with_weights(w, epochs=8000)\n    print(f\"Config {i+1}: {w} -> L2: {l2:.4e}, L_inf: {linf:.4e}\")"
   ]
