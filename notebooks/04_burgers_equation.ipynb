    # 3D surface comparison\nfig = plt.figure(figsize=(18, 10))\n\n# FD Reference\nax1 = fig.add_subplot(231, projection='3d')\nX, T = np.meshgrid(x_fd, t_fd)\nsurf1 = ax1.plot_surface(X, T, u_fd, cmap='RdBu_r', alpha=0.9, rstride=2, cstride=2)\nax1.set_xlabel('x'); ax1.set_ylabel('t'); ax1.set_zlabel('u')\nax1.set_title('FD Reference')\nfig.colorbar(surf1, ax=ax1, shrink=0.5)\n\n# PINN Prediction\nax2 = fig.add_subplot(232, projection='3d')\nsurf2 = ax2.plot_surface(X, T, u_best, cmap='RdBu_r', alpha=0.9, rstride=2, cstride=2)\nax2.set_xlabel('x'); ax2.set_ylabel('t'); ax2.set_zlabel('u')\nax2.set_title(f'PINN ({best_act})')\nfig.colorbar(surf2, ax=ax2, shrink=0.5)\n\n# Absolute Error\nax3 = fig.add_subplot(233, projection='3d')\nerror = np.abs(u_best - u_fd)\nsurf3 = ax3.plot_surface(X, T, error, cmap='hot', alpha=0.9, rstride=2, cstride=2)\nax3.set_xlabel('x'); ax3.set_ylabel('t'); ax3.set_zlabel('|Error|')\nax3.set_title('Absolute Error')\nfig.colorbar(surf3, ax=ax3, shrink=0.5)\n\n# Contour plots\nax4 = fig.add_subplot(234)\nim4 = ax4.contourf(X, T, u_fd, levels=50, cmap='RdBu_r')\nax4.set_xlabel('x'); ax4.set_ylabel('t'); ax4.set_title('FD Reference (contour)')\nfig.colorbar(im4, ax=ax4)\n\nax5 = fig.add_subplot(235)\nim5 = ax5.contourf(X, T, u_best, levels=50, cmap='RdBu_r')\nax5.set_xlabel('x'); ax5.set_ylabel('t'); ax5.set_title(f'PINN (contour)')\nfig.colorbar(im5, ax=ax5)\n\nax6 = fig.add_subplot(236)\nim6 = ax6.contourf(X, T, error, levels=50, cmap='hot')\nax6.set_xlabel('x'); ax6.set_ylabel('t'); ax6.set_title('Error (contour)')\nfig.colorbar(im6, ax=ax6)\n\nplt.tight_layout()\nplt.show()"
   ]
