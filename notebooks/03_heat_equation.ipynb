    def train_heat(config, epochs=5000):\n    \"\"\"Train heat PINN with given config.\"\"\"\n    torch.manual_seed(42)\n    \n    model = HeatPINN(hidden_dim=config['hidden_dim'], num_layers=config['num_layers'])\n    \n    # Sample points based on strategy\n    if config['sampling'] == 'uniform':\n        x_phys = torch.rand(config['n_phys'], 1) * (x_max - x_min) + x_min\n        t_phys = torch.rand(config['n_phys'], 1) * (t_max - t_min) + t_min\n    elif config['sampling'] == 'lhs':\n        from scipy.stats import qmc\n        sampler = qmc.LatinHypercube(d=2)\n        samples = sampler.random(config['n_phys'])\n        x_phys = torch.tensor(samples[:, 0:1] * (x_max - x_min) + x_min, dtype=torch.float32)\n        t_phys = torch.tensor(samples[:, 1:2] * (t_max - t_min) + t_min, dtype=torch.float32)\n    elif config['sampling'] == 'sobol':\n        from scipy.stats import qmc\n        sampler = qmc.Sobol(d=2, scramble=True)\n        samples = sampler.random(config['n_phys'])\n        x_phys = torch.tensor(samples[:, 0:1] * (x_max - x_min) + x_min, dtype=torch.float32)\n        t_phys = torch.tensor(samples[:, 1:2] * (t_max - t_min) + t_min, dtype=torch.float32)\n    \n    t_bound = torch.rand(2 * config['n_bound'], 1) * (t_max - t_min) + t_min\n    x_init = torch.rand(config['n_init'], 1) * (x_max - x_min) + x_min\n    \n    optimizer = optim.Adam(model.parameters(), lr=config['lr'])\n    \n    for epoch in range(epochs):\n        optimizer.zero_grad()\n        loss, _ = total_loss(model, x_phys, t_phys, t_bound, x_init)\n        loss.backward()\n        optimizer.step()\n    \n    # Evaluate\n    model.eval()\n    with torch.no_grad():\n        x_test = torch.linspace(x_min, x_max, 100).unsqueeze(1).repeat(1, 100).T.reshape(-1, 1)\n        t_test = torch.linspace(t_min, t_max, 100).unsqueeze(1).repeat(100, 1).reshape(-1, 1)\n        u_pred = model(x_test, t_test).reshape(100, 100).numpy()\n        u_true = analytical_solution(x_test, t_test).reshape(100, 100).numpy()\n        l2_rel = np.linalg.norm(u_pred - u_true) / np.linalg.norm(u_true)\n    \n    return l2_rel\n\n# Test configurations\nconfigs = [\n    {'name': 'Uniform, 64x5, lr=1e-3', 'hidden_dim': 64, 'num_layers': 5, 'lr': 1e-3, 'n_phys': 10000, 'n_bound': 1000, 'n_init': 1000, 'sampling': 'uniform'},\n    {'name': 'LHS, 64x5, lr=1e-3', 'hidden_dim': 64, 'num_layers': 5, 'lr': 1e-3, 'n_phys': 10000, 'n_bound': 1000, 'n_init': 1000, 'sampling': 'lhs'},\n    {'name': 'Sobol, 64x5, lr=1e-3', 'hidden_dim': 64, 'num_layers': 5, 'lr': 1e-3, 'n_phys': 10000, 'n_bound': 1000, 'n_init': 1000, 'sampling': 'sobol'},\n    {'name': 'Uniform, 128x5, lr=1e-3', 'hidden_dim': 128, 'num_layers': 5, 'lr': 1e-3, 'n_phys': 10000, 'n_bound': 1000, 'n_init': 1000, 'sampling': 'uniform'},\n    {'name': 'Uniform, 64x5, lr=1e-4', 'hidden_dim': 64, 'num_layers': 5, 'lr': 1e-4, 'n_phys': 10000, 'n_bound': 1000, 'n_init': 1000, 'sampling': 'uniform'},\n]\n\nprint(\"Running experiments...\")\nfor config in configs:\n    name = config.pop('name')\n    error = train_heat(config, epochs=3000)\n    print(f\"{name}: L2 rel error = {error:.4e}\")"
   ]
