    # Time slices\nmodel.eval()\nwith torch.no_grad():\n    x_plot = torch.linspace(x_min, x_max, 200).unsqueeze(1)\n    \n    fig, axes = plt.subplots(2, 3, figsize=(15, 8))\n    axes = axes.flatten()\n    \n    time_points = [0.0, 0.1, 0.25, 0.5, 0.75, 1.0]\n    \n    for i, t_val in enumerate(time_points):\n        t_plot = torch.full_like(x_plot, t_val)\n        u_pred = model(x_plot, t_plot).squeeze().numpy()\n        u_true = analytical_solution(x_plot, t_plot).squeeze().numpy()\n        \n        axes[i].plot(x_plot.numpy(), u_true, 'k--', label='Exact', linewidth=2)\n        axes[i].plot(x_plot.numpy(), u_pred, 'b-', label='PINN', linewidth=2)\n        axes[i].set_xlabel('x')\n        axes[i].set_ylabel('u')\n        axes[i].set_title(f't = {t_val}')\n        axes[i].legend()\n        axes[i].grid(True, alpha=0.3)\n        axes[i].set_ylim(-0.1, 1.1)\n    \n    plt.tight_layout()\n    plt.show()"
   ]
