  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Residual Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    # Compute residual field\nmodel.eval()\nwith torch.enable_grad():\n    x_res = torch.linspace(x_min, x_max, 50).unsqueeze(1).repeat(1, 50).T.reshape(-1, 1).requires_grad_(True)\n    t_res = torch.linspace(t_min, t_max, 50).unsqueeze(1).repeat(50, 1).reshape(-1, 1).requires_grad_(True)\n    \n    u_res = model(x_res, t_res)\n    u_t = torch.autograd.grad(u_res.sum(), t_res, create_graph=True, retain_graph=True)[0]\n    u_x = torch.autograd.grad(u_res.sum(), x_res, create_graph=True, retain_graph=True)[0]\n    u_xx = torch.autograd.grad(u_x.sum(), x_res, create_graph=True, retain_graph=True)[0]\n    \n    residual = (u_t - ALPHA * u_xx).detach().reshape(50, 50).numpy()\n    X_res = x_res.detach().reshape(50, 50).numpy()\n    T_res = t_res.detach().reshape(50, 50).numpy()\n\nfig, axes = plt.subplots(1, 2, figsize=(12, 4))\nim1 = axes[0].contourf(X_res, T_res, residual, levels=50, cmap='RdBu_r')\naxes[0].set_xlabel('x'); axes[0].set_ylabel('t')\naxes[0].set_title('Physics Residual')\nplt.colorbar(im1, ax=axes[0])\n\naxes[1].scatter(X_res.flatten(), residual.flatten(), s=1, alpha=0.5)\naxes[1].set_xlabel('x'); axes[1].set_ylabel('Residual')\naxes[1].set_title('Residual vs x')\naxes[1].grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.show()\n\nprint(f\"Max |residual|: {np.max(np.abs(residual)):.2e}\")\nprint(f\"Mean |residual|: {np.mean(np.abs(residual)):.2e}\")"
   ]
